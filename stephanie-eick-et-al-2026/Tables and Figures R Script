#### Table S1
Table S1: Distribution of individual stressful life events (SLEs) across SLE categories in the San Francisco Womenâ€™s Option Center (WOC-SF, 2010-2016) and Atlanta African American Maternal-Child Cohort (ATL, 2015-2019), not matched on propensity scores.  

```{r}

stress_columns <- c(
  "argued_with_partner",
  "bills_couldnt_pay",
  "drug_drinks_someoneclose",
  "partner_legal_problems",
  "moved",
  "lost_job",
  "passed_away_someoneclose",
  "partner_lost_job",
  "separated_divorced",
  "very_sick_someoneclose"
)

cross_table <- function (df, stressor) {
  df %>%
  filter({{stressor}} == "1") %>%
  mutate(across(all_of(stress_columns), ~ as.numeric(as.character(.)))) %>%
  mutate(stress_total = rowSums(select(., all_of(stress_columns)), na.rm = TRUE),
         stress_group = case_when(
           stress_total <= 3 ~ "1-3 SLEs",
           stress_total > 3 ~ "â‰Ą 4 SLEs")) %>%
  group_by(stress_group) %>%
  summarise(count = n()) %>%
  mutate(sle = as_label(enquo(stressor)))
}

table_s1_woc <- map_dfr(stress_columns, ~cross_table(df = woc_mat_full, stressor = !!sym(.x))) %>%
  mutate(df = "WOC-SF")
table_s1_atl <- map_dfr(stress_columns, ~cross_table(df = atl_full, stressor = !!sym(.x)))%>%
  mutate(df = "ATL")

bind_rows(table_s1_woc, table_s1_atl) %>%
  pivot_wider(names_from = stress_group, values_from = count) %>%
  gt(groupname_col = "sle", rowname_col = "df") %>%
  cols_label()
```

