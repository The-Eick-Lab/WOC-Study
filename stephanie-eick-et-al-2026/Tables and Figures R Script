## Descriptive statistics 

#### Figure S1

Illustration of the area of common support with propensity scores for individuals in both cohorts.

Note: The propensity scores for those in the Atlanta Maternal Child Cohort (ATL) are represented in blue, while the propensity scores for those in the Womenâ€™s Option Center (WOC) are in red. The leftmost dashed line indicates where the minimum propensity score for those who were in the WOC occurs, and the rightmost dashed line indicates where the maximum propensity score for those who were in ATL. The area of common support is the area within these two dashed lines, where individuals within both cohorts had similar propensity scores.

```{r class.output="scroll-500", message = FALSE, fig.width=20, fig.height = 15}
# create categorical age and bmi 
pooled <- pooled %>% 
  mutate(mat_bmi_cat = case_when(
    mat_bmi < 25 ~ "0", 
    mat_bmi >= 25 & mat_bmi < 30 ~ "1", 
    mat_bmi >= 30 ~ "2")) %>%
  mutate(mat_age_cat = case_when(
   mat_age < 20 ~ "0",
   mat_age >= 20 & mat_age < 25 ~ "1",
   mat_age >= 25 & mat_age < 30 ~ "2",
   mat_age >= 30 ~ "3"))

# correct data types
pooled$mat_bmi_cat <- as.factor(pooled$mat_bmi_cat)
pooled$mat_age_cat <- as.factor(pooled$mat_age_cat)
pooled$cohort <- as.factor(pooled$cohort)

# run regression
prop <- glm(cohort ~ marital + mat_educ + parity + mat_bmi_cat + mat_age_cat + smoke, data=pooled, family="binomial")

summary(prop)

# calculate propensity scores
pooled_p <- pooled %>% drop_na(marital, mat_educ, parity, mat_bmi_cat, mat_age_cat, smoke)
pooled_p$p <- predict(prop, type="response")


 ggplot(pooled_p, aes(x=p, fill=factor(cohort))) + 
   geom_histogram(alpha=0.75, position="identity")  +
   scale_fill_manual(values=c("#b2182b", "#2166ac"), labels=c("ATL","WOC"), name=NULL) + 
  geom_vline(xintercept=min(pooled_p$p[pooled_p$cohort==1]), linetype=2) + geom_vline(xintercept=max(pooled_p$p[pooled_p$cohort==0]), linetype=2) +
  labs(x="Estimated Propensity Score", y="Density") +
   theme(legend.position = "bottom",  text = element_text(family = "Optima", size=25),
         axis.title.x = element_text(size = 25, color = "grey10"),
        axis.title.y = element_text(size = 25, color = "grey10"),
         axis.text.x = element_text(size = 25, color = "grey10"),
        axis.text.y = element_text(size = 25, color = "grey10"))
 
 # next, nearest neighbor without replace matching
set.seed(142)
pooled_m <- pooled_p %>%
  filter(p >= min(p[pooled_p$cohort == 1]) & p <= max(p[pooled_p$cohort == 0]))
m.out <- matchit(cohort ~ marital + mat_educ + smoke + parity + mat_bmi_cat + mat_age_cat, data=pooled_p, method = "nearest")
summary(m.out)
matched <- match_data(m.out)


# create weights: for ATL, this is 1/1-propensity score, for WOC, this is 1/propensity score
matched$ps_weight<-ifelse(matched$cohort==1, 1/matched$p,
                       ifelse(matched$cohort==0, 1/(1-matched$p),NA))

# restrict datasets to only matching ids
atl_m <- inner_join(atl, matched)
woc_mat_m <- inner_join(woc_mat, matched)

```

