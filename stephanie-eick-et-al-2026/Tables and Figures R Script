# build function to calculate summary measures: geometric mean, geometric sd, min, med, max
dist.func <- function(x) {
  c(
    geomean = round(exp(mean(log(x), na.rm = TRUE)), 2),
    geosd = round(exp(sd(log(x), na.rm = TRUE)), 2),
    min = round(min(x, na.rm = TRUE), 2),
    med = round(median(x, na.rm = TRUE), 2),
    max = round(max(x, na.rm = TRUE), 2)
  )
}

# apply to each cohort

